# ══════════════════════════════════════════════════════════════════════════════
# SistemaVentas — Plantilla de Variables de Entorno (Backend Django)
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCCIONES DE USO:
#   1. Copia este archivo con el nombre ".env" en el mismo directorio.
#   2. Rellena los valores reales en el archivo ".env".
#   3. NUNCA subas el archivo ".env" al repositorio (está en .gitignore).
#      El archivo ".env" contiene credenciales reales y su exposición en un
#      repositorio público comprometería la seguridad completa del sistema.
#
# POR QUÉ USAMOS VARIABLES DE ENTORNO:
#   - Principio de "12-Factor App": La configuración que cambia entre entornos
#     (desarrollo, staging, producción) debe vivir en el entorno, no en el código.
#   - La SECRET_KEY de Django se usa para firmar cookies de sesión y tokens CSRF.
#     Si se filtra, un atacante puede forjar cualquier sesión de usuario.
#   - Las credenciales de BD expuestas permiten acceso directo a todos los datos.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Django Core ─────────────────────────────────────────────────────────────
# SECRET_KEY: Clave criptográfica usada por Django para:
#   - Firmar tokens CSRF (Cross-Site Request Forgery protection)
#   - Firmar cookies de sesión
#   - Hashear tokens de reset de contraseña
# Genera una nueva con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=genera-una-clave-segura-aqui

# DEBUG: En producción DEBE ser False.
# Con DEBUG=True Django muestra trazas de errores completas al usuario,
# lo que puede exponer rutas internas, nombres de variables y lógica de negocio.
DEBUG=True

# ALLOWED_HOSTS: Lista de dominios/IPs que pueden servir esta aplicación.
# En producción, incluir el dominio real (ej: mi-tienda.com,www.mi-tienda.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de Datos PostgreSQL ─────────────────────────────────────────────────
# Se usa PostgreSQL porque el sistema aprovecha procedimientos almacenados
# (funciones PL/pgSQL) avanzados para los reportes gerenciales.
# MySQL/SQLite no soportan la sintaxis de estas funciones.
DB_NAME=bendicion_de_dios
DB_USER=postgres
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432
